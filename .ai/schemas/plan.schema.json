{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://platform.local/schemas/plan.schema.json",
  "title": "plan",
  "description": "Planner output (§11.2/§11.3): a task graph tracing every task to acceptance criteria. Mirrors core/src/planning-gate.ts PlannedTask.",
  "type": "object",
  "required": ["tasks"],
  "additionalProperties": true,
  "properties": {
    "planId": { "type": "string" },
    "goalId": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["taskId", "mapsToAc", "estimatedDiffBytes"],
        "additionalProperties": true,
        "properties": {
          "taskId": { "type": "string" },
          "mapsToAc": { "type": "array", "items": { "type": "string" } },
          "deps": { "type": "array", "items": { "type": "string" } },
          "enabling": { "type": "boolean" },
          "risk": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
          "estimatedDiffBytes": { "type": "integer" }
        }
      }
    }
  }
}
